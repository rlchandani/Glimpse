{
  "permissions": {
    "allow": [
      "Bash(xcodebuild *)",
      "Bash(swift test *)",
      "Bash(swift test)",
      "Bash(open *)",
      "Bash(git *)",
      "Bash(ls *)",
      "Bash(find *)",
      "Bash(du *)",
      "Bash(cat *)",
      "Bash(grep *)",
      "Bash(cd *)",
      "Bash(mkdir *)",
      "Bash(cp *)",
      "Bash(mv *)",
      "Bash(rm *)",
      "Bash(echo *)",
      "Bash(which *)"
    ]
  },
  "hooks": {
    "PreCommit": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "cd GlimpseCore && swift test --quiet 2>&1 | tail -5"
          }
        ]
      }
    ]
  }
}
